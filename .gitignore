# Unity-generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Burst / Player builds
*BurstDebugInformation_DoNotShip/
*_BackUpThisFolder_ButDontShipItWithYourGame/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autocreated Visual Studio / Rider / etc.
.vs/
.vsconfig
.idea/
.vscode/
.utmp/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.app/
*.unitypackage
*.zip
*.ipa

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Meta XR / OVR / build runtime
RuntimeActionBindings.json
RuntimeActionBindings.json.meta
buildInfo.txt
buildInfo.txt.meta
ProjectSettings/Packages/com.unity.testtools.codecoverage/Settings.json

# CompositionLayers user prefs (Unity regenerates per user)
/[Aa]ssets/[Cc]omposition[Ll]ayers/

# Test / performance artefacts
PerformanceTestRun*.*

# Locked package manifest (regenerated by Unity)
Packages/packages-lock.json

# OS junk
.DS_Store
Thumbs.db
